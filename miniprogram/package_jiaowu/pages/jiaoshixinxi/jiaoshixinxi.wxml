<scroll-view class="sv_list" scroll-x="true" scroll-y="true" style="height:88%">
  <view class="table">
    <view class='table_header'>
      <block class="title" wx:for="{{title}}">
        <view class="title_text" style="width:{{item.width}};{{item.text==''?'position:sticky;left:0;z-index:5':''}}">{{item.text}}</view>
      </block>
    </view>
    <block class="list_row" wx:for="{{list}}" wx:for-item="list_item" wx:for-index="i" wx:key="id">
  <view class="table_main">
    <block wx:for="{{title}}" wx:for-item="item" wx:key="item">
      <!-- 文件列特殊处理 -->
      <block wx:if="{{item.columnName == 'wenjian'}}">
        <view class="list_view" style="width:{{item.width}}; display: flex; align-items: center; justify-content: center;">
          <view style="display: flex; flex-direction: row; justify-content: center; align-items: center; flex-wrap: wrap;">
            <!-- 如果wenjian字段为空或空字符串，显示上传按钮 -->
            <block wx:if="{{!list_item.wenjian || list_item.wenjian === ''}}">
              <button 
                class="upload-btn" 
                bindtap="showUploadModalFunc" 
                data-id="{{list_item.id}}" 
                data-name="{{list_item.t_name || ''}}"
                size="mini"
                style="background: #4CAF50; color: white; font-size: 20rpx; padding: 5rpx 10rpx; line-height: 1.5; min-width: 80rpx; margin: 5rpx;"
              >
                上传
              </button>
            </block>
            
            <!-- 如果wenjian字段有值，显示查看按钮和上传按钮 -->
            <block wx:else>
              <button 
                class="view-btn" 
                bindtap="viewFiles" 
                data-id="{{list_item.id}}" 
                data-name="{{list_item.t_name || ''}}"
                size="mini"
                style="background: #2196F3; color: white; font-size: 20rpx; padding: 5rpx 10rpx; line-height: 1.5; min-width: 80rpx; margin: 5rpx;"
              >
                查看
              </button>
              <!-- <button 
                class="upload-btn" 
                bindtap="showUploadModalFunc" 
                data-id="{{list_item.id}}" 
                data-name="{{list_item.t_name || ''}}"
                size="mini"
                style="background: #4CAF50; color: white; font-size: 20rpx; padding: 5rpx 10rpx; line-height: 1.5; min-width: 80rpx; margin: 5rpx;"
              >
                上传
              </button> -->
            </block>
          </view>
        </view>
      </block>
      
      <!-- 其他列正常显示 -->
      <block wx:else>
        <view class="list_view" 
              style="width:{{item.width}}" 
              data-index="{{i}}" 
              data-column="{{item.columnName}}" 
              data-value="{{list_item[item.columnName]}}" 
              data-input_type="{{item.type}}"
              data-isupd="{{item.isupd}}"
              bindtap="clickView">
          <view class="list_text">{{item.columnName == 'rownum' ? i+1 : list_item[item.columnName]}}</view>
        </view>
      </block>
    </block>
  </view>
</block>
  </view>
</scroll-view>



