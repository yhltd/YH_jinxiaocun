<scroll-view class="sv_list" scroll-x="true" scroll-y="true">
  <view class="table">
    <view class='table_header'>
      <block class="title" wx:for="{{titil}}">
        <view class="title_text" style="width:{{item.width}};{{item.text=='序号'?'position:sticky;background:#8e97a9;left:0':''}}">{{item.text}}</view>
      </block>
    </view> 
    <block class="list_row">
      <view class="table_main" wx:for="{{list}}" wx:for-item="list_item" wx:key="id">
        <view class="list_view" style="width:100rpx;position:sticky;background-color: white;left:0">
          <view wx:if="{{!isDelete}}" class="list_text">{{list_item.ROW_ID}}</view>
          <view wx:if="{{isDelete}}">
            <checkbox-group bindchange="choice_checkBox_delete" data-id="{{list_item.id}}">
              <checkbox style="width: 62rpx;margin-bottom: 8rpx;" value="{{list_item.id}}" color="#282B33"/>
            </checkbox-group>
          </view>
        </view>
        <view class="list_view" style="width:250rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="insert_date" data-value="{{list_item.insert_date}}" bindtap="clickView" data-input_type="text">
          <view class="list_text">{{list_item.insert_date}}</view>
        </view>
        <view class="list_view" style="width:250rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="kehu" data-value="{{list_item.kehu}}" bindtap="clickView" data-input_type="text">
          <view class="list_text">{{list_item.kehu}}</view>
        </view>
        <view class="list_view" style="width:250rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="project" data-value="{{list_item.project}}" bindtap="clickView" data-input_type="text">
          <view class="list_text">{{list_item.project}}</view>
        </view>
        <view class="list_view" style="width:170rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="receivable" data-value="{{list_item.receivable}}" bindtap="clickView" data-input_type="number">
          <view class="list_text">{{list_item.receivable}}</view>
        </view>
        <view class="list_view" style="width:170rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="receipts" data-value="{{list_item.receipts}}" bindtap="clickView" data-input_type="number">
          <view class="list_text">{{list_item.receipts}}</view>
        </view>
        <view class="list_view" style="width:170rpx">
          <view class="list_text">{{list_item.notget1}}</view>
        </view>
        <view class="list_view" style="width:170rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="cope" data-value="{{list_item.cope}}" bindtap="clickView" data-input_type="number">
          <view class="list_text">{{list_item.cope}}</view>
        </view>
        <view class="list_view" style="width:170rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="payment" data-value="{{list_item.payment}}" bindtap="clickView" data-input_type="number">
          <view class="list_text">{{list_item.payment}}</view>
        </view>
        <view class="list_view" style="width:170rpx">
          <view class="list_text">{{list_item.notget2}}</view>
        </view>
        <view class="list_view" style="width:250rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="accounting" data-value="{{list_item.accounting}}" bindtap="clickView" data-input_type="text">
          <view class="list_text">{{list_item.accounting}}</view>
        </view>
        <view class="list_view" style="width:250rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="nashuijine" data-value="{{list_item.nashuijine}}" bindtap="clickView" data-input_type="number">
          <view class="list_text">{{list_item.nashuijine}}</view>
        </view>
        <view class="list_view" style="width:250rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="yijiaoshuijine" data-value="{{list_item.yijiaoshuijine}}" bindtap="clickView" data-input_type="number">
          <view class="list_text">{{list_item.yijiaoshuijine}}</view>
        </view>
        <view class="list_view" style="width:250rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="weijiaoshuijine" data-value="{{list_item.weijiaoshuijine}}" bindtap="clickView" data-input_type="number">
          <view class="list_text">{{list_item.weijiaoshuijine}}</view>
        </view>
        <view class="list_view" style="width:250rpx" data-index="{{index}}" data-id="{{list_item.id}}" data-column="zhaiyao" data-value="{{list_item.zhaiyao}}" bindtap="clickView" data-input_type="text">
          <view class="list_text">{{list_item.zhaiyao}}</view>
        </view>
        <view class="list_view" style="width:160rpx;">
        <view style="display: flex; flex-direction: row; justify-content: center; align-items: center;">
          <!-- 如果wenjian字段为空或空字符串，显示上传按钮 -->
          <block wx:if="{{!list_item.wenjian || list_item.wenjian === ''}}">
            <button 
              class="upload-btn" 
              bindtap="showUploadModalFunc" 
              data-id="{{list_item.id}}" 
              data-name="{{list_item.kehu || ''}}"
              size="mini"
              style="background: #4CAF50; color: white; font-size: 20rpx; padding: 5rpx 10rpx; line-height: 1.5; min-width: 80rpx;"
            >
              上传
            </button>
          </block>
          
          <!-- 如果wenjian字段有值，显示查看按钮 -->
          <block wx:else>
            <button 
              class="view-btn" 
              bindtap="viewFiles" 
              data-id="{{list_item.id}}" 
              data-name="{{list_item.kehu || ''}}"
              size="mini"
              style="background: #2196F3; color: white; font-size: 20rpx; padding: 5rpx 10rpx; line-height: 1.5; min-width: 80rpx; margin-right: 5rpx;"
            >
              查看
            </button>
          </block>
        </view>
  </view>
      </view>
    </block>
  </view>
</scroll-view>

<!-- 文件上传弹窗 -->
<tui-modal show="{{showUploadModal}}" bind:cancel="hideUploadModal" custom="{{true}}" fadein="{{true}}">
  <view style="text-align: center; padding: 40rpx;">
    <view style="font-size: 36rpx; font-weight: bold; margin-bottom: 40rpx;">上传文件</view>
    
    <!-- 文件名称输入 -->
    <view style="margin-bottom: 30rpx;">
      <view style="text-align: left; font-size: 28rpx; margin-bottom: 10rpx; color: #666;">文件名称</view>
      <input 
        placeholder="请输入文件名称" 
        value="{{fileName}}"
        bindinput="onFileNameInput"
        style="border: 1rpx solid #e6e6e6; border-radius: 10rpx; padding: 20rpx; font-size: 28rpx;"
      />
    </view>
    
    <!-- 文件选择 -->
    <view style="margin-bottom: 30rpx;">
      <view style="text-align: left; font-size: 28rpx; margin-bottom: 10rpx; color: #666;">选择文件</view>
      <view style="display: flex; justify-content: space-between;">
        <button 
          bindtap="chooseImage"
          style="width: 48%; font-size: 28rpx;"
          size="mini"
        >
          选择图片
        </button>
        <button 
          bindtap="chooseFile"
          style="width: 48%; font-size: 28rpx;"
          size="mini"
        >
          选择文档
        </button>
      </view>
      
      <!-- 已选文件列表 -->
      <view wx:if="{{selectedFiles.length > 0}}" style="margin-top: 20rpx;">
        <view style="font-size: 26rpx; color: #666; margin-bottom: 10rpx;">
          已选择 {{selectedFiles.length}} 个文件
        </view>
        <scroll-view scroll-y style="max-height: 200rpx; border: 1rpx solid #eee; border-radius: 10rpx; padding: 10rpx;">
          <view wx:for="{{selectedFiles}}" wx:key="index" style="font-size: 24rpx; color: #333; padding: 5rpx 0;">
            {{index + 1}}. {{item.name}} ({{Math.round(item.size/1024)}}KB)
          </view>
        </scroll-view>
      </view>
    </view>
    
    <!-- 上传进度 -->
    <view wx:if="{{uploading}}" style="margin-bottom: 30rpx;">
      <view style="font-size: 28rpx; color: #666; margin-bottom: 10rpx;">
        上传进度: {{uploadProgress}}%
      </view>
      <progress 
        percent="{{uploadProgress}}" 
        show-info 
        stroke-width="6"
        color="#5677fc"
      />
    </view>
    
    <!-- 操作按钮 -->
    <view style="display: flex; justify-content: space-between; margin-top: 40rpx;">
      <button 
        bindtap="hideUploadModal"
        style="width: 48%; background: #f5f5f5; color: #666;"
        hover-class="btn-hover"
        disabled="{{uploading}}"
      >
        取消
      </button>
      <button 
        bindtap="uploadFile"
        style="width: 48%; background: #5677fc; color: white;"
        hover-class="btn-hover"
        disabled="{{uploading || selectedFiles.length === 0}}"
      >
        {{uploading ? '上传中...' : '上传'}}
      </button>
    </view>
  </view>
</tui-modal>

<!-- 文件查看弹窗 -->
<tui-modal show="{{showFileViewModal}}" bind:cancel="hideFileViewModal" custom="{{true}}" fadein="{{true}}" width="90%">
  <view style="text-align: center; max-height: 80vh; overflow: hidden;">
    <view style="font-size: 36rpx; font-weight: bold; margin-bottom: 30rpx;">文件列表 - {{currentFileName}}</view>
    
    <!-- 可左右滑动的文件列表容器 -->
    <scroll-view scroll-x="true" style="width: 100%; white-space: nowrap;">
      <!-- 文件列表 - 横向排列 -->
      <view wx:if="{{currentFileList && currentFileList.length > 0}}" style="display: inline-flex; flex-direction: row;">
        <view wx:for="{{currentFileList}}" wx:key="index" wx:for-item="fileItem" style="width: 90%; margin-right: 20rpx; display: inline-block; vertical-align: top; white-space: normal;">
          <view style="margin-bottom: 20rpx; padding: 20rpx; border: 1rpx solid #e6e6e6; border-radius: 10rpx;">
            <view style="display: flex; align-items: center; justify-content: space-between;">
              <view style="flex: 1; text-align: left;">
                <view style="font-size: 28rpx; color: #333; margin-bottom: 5rpx; word-break: break-all;">
                  {{index + 1}}. {{fileItem.displayName || fileItem.split('/').pop()}}
                </view>
                <view style="font-size: 24rpx; color: #666;">
                  {{fileItem.url || fileItem}}
                </view>
              </view>
              <view style="display: flex; flex-direction: column;">
                <!-- 预览按钮 -->
                <button 
                  bindtap="previewFile" 
                  data-url="{{fileItem.url || fileItem}}"
                  style="font-size: 24rpx; padding: 10rpx 15rpx; margin-bottom: 10rpx; background: #5677fc; color: white;"
                  size="mini"
                >
                  预览
                </button>
                <!-- 删除按钮 -->
                <button 
                  bindtap="deleteFile" 
                  data-url="{{fileItem.url || fileItem}}"
                  data-id="{{currentRecordId}}"
                  style="font-size: 24rpx; padding: 10rpx 15rpx; background: #ff4444; color: white;"
                  size="mini"
                >
                  删除
                </button>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <view wx:else style="display: flex; justify-content: center; align-items: center; height: 400rpx; width: 100%;">
        <view style="padding: 60rpx 0; color: #999; font-size: 28rpx;">
          暂无文件
        </view>
      </view>
    </scroll-view>
    
    <!-- 关闭按钮放在外部，保持固定 -->
    <view style="margin-top: 30rpx;">
      <button 
        bindtap="hideFileViewModal"
        style="width: 100%; background: #5677fc; color: white;"
        hover-class="btn-hover"
      >
        关闭
      </button>
    </view>
  </view>
</tui-modal>

<view class="input_view" animation="{{animationData_input}}" hidden="{{initHidView?initHidView:''}}">
  <form bindsubmit="save">
    <view>
      <view class="input_message">修改内容</view>
      <input class="input_text_form" placeholder="{{value_input}}" value="{{empty}}" type="{{input_type}}" name="new"></input>
    </view>
    <view class="bt_view">  
      <button class="bt_form" bindtap="hid_view" hover-class="bt_form_hover">取消</button>
      <button class="bt_form" form-type="submit" hover-class="bt_form_hover">确定</button>
    </view>
  </form>

</view>

<view class="bottom_view">
  <view>
    <button class="bt_bottom" hover-class="bt_bottom_hover" bindtap="switchpage" data-index="-1">{{'<<'}}</button>
    <view class="page_bottom" bindtap="show_updPageCount">{{pageNum}}/{{pageCount}}</view>
    <button class="bt_bottom" bindtap="switchpage" data-index="+1">{{'>>'}}</button>
  </view>
  <view class="backSelect" wx:if="{{isDelete}}" bindtap="backDelete">
    <image class="backSelect_image" src="cloud://yhltd-hsxl2.7968-yhltd-hsxl2-1259412419/pakageC_image/backSelect1.jpg"></image>
  </view>
  <button class="moreDo" bindtap="{{isDelete?'delete':'moreDo'}}">{{isDelete?'删除':'更多操作'}}</button>
</view>

<view class="moreDo_view" animation="{{animationData_moreDo_view}}" hidden="{{initHidView?'true':''}}">
  <button class="moreDo_view_bt" bindtap="bindDelete">删除项目</button>
  <button class="moreDo_view_bt" bindtap="insert">新增项目</button>
  <button class="moreDo_view_bt" bindtap="chaxun_show">查询</button>
  <button class="moreDo_view_bt" bindtap="use_book">使用说明</button>
</view>

<view class="mask" wx:if="{{hid_view}}" bindtap="{{hid_view?'hid_view':''}}" hidden="{{initHidView?'true':''}}">
</view>

<view class="mask" bindtap="chaxun_quxiao" hidden="{{chaxun_hidden}}">
</view>

<view class="select_view_box" animation="{{animationData_select_view}}" hidden="{{chaxun_hidden}}">
  <form bindsubmit="select">
    <view class="option">
      <input class="option_text" value="{{xiangmumingcheng}}" bindinput="input" placeholder="请输入项目名称" name="xiangmumingcheng"/>
      <picker class="date-picker" mode="date"  bindchange="showChoiceMonth1">
        <input class="option_text" value="{{start_date}}" bindinput="input" placeholder="请输入开始日期" name="start_date" disabled='disabled'/>
      </picker>
      <picker class="date-picker" mode="date"  bindchange="showChoiceMonth2">
        <input class="option_text" value="{{stop_date}}" bindinput="input" placeholder="请输入结束日期" name="stop_date" disabled='disabled'/>
      </picker>
    </view>
    <view class="moreDo_bt_view" >
      <button class="moreDo_bt" bindtap="chaxun_quxiao">返回</button>
      <button class="moreDo_bt" form-type="submit">查询</button>
    </view>
  </form>
</view>
